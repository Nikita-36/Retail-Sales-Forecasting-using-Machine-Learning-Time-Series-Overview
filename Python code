import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

from sklearn.model_selection import train_test_split
from sklearn.linear_model import LinearRegression
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_absolute_error

from statsmodels.tsa.arima.model import ARIMA

df = pd.read_csv("retail_sales_dataset.csv")

print(df.head())
print(df.info())
print(df.describe())
print(df.isnull().sum())

df["Date"] = pd.to_datetime(df["Date"])

df = df.sort_values("Date")

daily_sales = df.groupby("Date")["Total Amount"].sum().reset_index()

daily_sales["Day"] = daily_sales["Date"].dt.day
daily_sales["Month"] = daily_sales["Date"].dt.month
daily_sales["Year"] = daily_sales["Date"].dt.year
daily_sales["DayOfWeek"] = daily_sales["Date"].dt.dayofweek

X = daily_sales[["Day", "Month", "Year", "DayOfWeek"]]
y = daily_sales["Total Amount"]

split = int(len(daily_sales) * 0.8)

X_train = X.iloc[:split]
X_test = X.iloc[split:]

y_train = y.iloc[:split]
y_test = y.iloc[split:]

lr = LinearRegression()

lr.fit(X_train, y_train)

lr_pred = lr.predict(X_test)

lr_mae = mean_absolute_error(y_test, lr_pred)

print("\nLinear Regression MAE:", lr_mae)

rf = RandomForestRegressor(
    n_estimators=100,
    random_state=42
)

rf.fit(X_train, y_train)

rf_pred = rf.predict(X_test)

rf_mae = mean_absolute_error(y_test, rf_pred)

print("Random Forest MAE:", rf_mae)

train_series = daily_sales["Total Amount"][:split]

test_series = daily_sales["Total Amount"][split:]

arima = ARIMA(train_series, order=(5,1,0))

arima_model = arima.fit()

arima_pred = arima_model.forecast(steps=len(test_series))

arima_mae = mean_absolute_error(test_series, arima_pred)

print("ARIMA MAE:", arima_mae)

print("\nModel Performance")

print("Linear Regression MAE :", lr_mae)

print("Random Forest MAE :", rf_mae)

print("ARIMA MAE :", arima_mae)

plt.figure(figsize=(12,6))

plt.plot(
    daily_sales["Date"][split:],
    y_test.values,
    label="Actual Sales"
)

plt.plot(
    daily_sales["Date"][split:],
    rf_pred,
    label="Random Forest Prediction"
)

plt.xlabel("Date")

plt.ylabel("Sales")

plt.title("Actual vs Predicted Sales")

plt.legend()

plt.show()

future_forecast = arima_model.forecast(steps=7)

future_dates = pd.date_range(
    start=daily_sales["Date"].max() + pd.Timedelta(days=1),
    periods=7
)

forecast = pd.DataFrame({
    "Date": future_dates,
    "Forecast Sales": future_forecast
})

print("\nNext 7 Days Sales Forecast")

print(forecast)

plt.figure(figsize=(10,5))

plt.plot(
    future_dates,
    future_forecast,
    marker="o"
)

plt.title("Next 7 Days Sales Forecast")

plt.xlabel("Date")

plt.ylabel("Forecast Sales")

plt.show()
